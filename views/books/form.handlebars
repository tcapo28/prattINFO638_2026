<form action="/books/upsert" role="form" method="post">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" {{#if book}}value="{{book.title}}"{{/if}}>
  </div>
  <div>
    <label for="year_published">Year Published</label>
    <input type="text" id="year_published" name="yearPublished" {{#if book}}value="{{book.yearPublished}}"{{/if}}>
  </div>
  <button type="submit" class="btn btn-primary">Submit</button>
    {{#if book}}
    <div>
      <h2>{{book.title}} {{book.yearPublished}}</h2>
      <input type="hidden" name="id" value="{{bookIndex}}">
    </div>
  {{/if}}
</form>